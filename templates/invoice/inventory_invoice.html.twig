<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Inventory Document - {{ documentNumber }}</title>
    <style>
        @page {
            margin: 130px 30px 140px 30px;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 11px;
            color: #333;
        }

        /* Header (Repeating) */
        .header {
            position: fixed;
            top: -110px;
            left: 0px;
            right: 0px;
            height: 100px;
            border-bottom: 2px solid #cda34f;
        }

        /* Footer (Repeating) */
        .footer {
            position: fixed;
            bottom: -70px;
            left: 0px;
            right: 0px;
            height: 90px;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 28px;
            font-weight: bold;
            color: #2e5aac;
        }

        .doc-type {
            font-size: 11px;
            font-weight: bold;
            color: #777;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: right;
            margin-top: -5px;
        }

        /* Meta */
        .invoice-meta td {
            padding: 2px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 15px 0;
            clear: both;
        }

        /* Section */
        .section-title {
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 5px;
            color: #2e5aac;
        }

        /* Info Card */
        .info-card {
            background: #f8f9fa;
            padding: 10px;
            border-radius: 4px;
            border: 1px solid #ddd;
            min-height: 80px;
        }

        .info-label { font-size: 9px; font-weight: bold; color: #777; text-transform: uppercase; margin-bottom: 2px; }
        .info-value { font-size: 11px; font-weight: bold; color: #333; }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 11px;
            text-align: left;
            text-transform: uppercase;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
            border-bottom: 1px solid #ddd;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        .last-page-footer {
            position: absolute;
            bottom: 40px;
            left: 0;
            right: 0;
            text-align: center;
        }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td { border-bottom: none; }

        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
        
        .badge { display: inline-block; padding: 4px 10px; border-radius: 4px; font-size: 9px; font-weight: bold; text-transform: uppercase; }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-info { background: #e0f2fe; color: #0369a1; }
        
        .footer-note {
            margin-top: 40px; text-align: center; color: #777; font-size: 10px; font-weight: bold;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        {% if showHeader %}
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo is defined and logo %}<img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="UHS">{% else %}<div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>{% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #1b2a88; color: #ffffff; display: inline-block; padding: 5px 15px; font-size: 13px; font-weight: bold;">
                        EXCELLENT IN DIAGNOSTIC SERVICES
                    </div>
                </td>
            </tr>
        </table>
        {% endif %}
    </div>

    <div class="container">
        <!-- HORIZONTAL INFO SECTION -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="55%" valign="top">
                    <div class="section-title">Record Details:</div>
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="48%" valign="top">
                                <div class="info-card">
                                    <div class="info-label">Action Performed By</div>
                                    <div class="info-value">Lab Administrator</div>
                                    <div style="margin-top: 8px;" class="info-label">Organization</div>
                                    <div class="info-value">UHS Management</div>
                                </div>
                            </td>
                            <td width="4%"></td>
                            <td width="48%" valign="top">
                                <div class="info-card">
                                    <div class="info-label">Action Type</div>
                                    <div class="info-value">
                                        <span class="badge {{ type == 'stock_in' ? 'badge-success' : 'badge-info' }}">
                                            {{ type == 'stock_in' ? 'STOCK REFILL' : (isEditing ? 'METADATA UPDATE' : 'REGISTRATION') }}
                                        </span>
                                    </div>
                                    <div style="margin-top: 8px;" class="info-label">Status</div>
                                    <div class="info-value">Verified & Recorded</div>
                                </div>
                            </td>
                        </tr>
                    </table>
                </td>
                <td width="45%" valign="top" align="right">
                    <div class="invoice-title">{{ documentTitle }}</div>
                    <div class="doc-type">Laboratory Inventory Log</div>
                    <table class="invoice-meta" align="right" style="margin-top: 10px;">
                        <tr><td><strong>Ref No:</strong></td><td style="padding-left: 15px; font-weight: bold;">#{{ documentNumber }}</td></tr>
                        <tr><td><strong>Date:</strong></td><td style="padding-left: 15px;">{{ date|date('d M Y, h:i A') }}</td></tr>
                        <tr><td><strong>Maker:</strong></td><td style="padding-left: 15px;">{{ invoiceMaker|default('N/A') }}</td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <!-- ITEMIZED SUMMARY -->
        <table class="table">
            <thead>
                <tr>
                    <th width="40%">Item / Reagent Name</th>
                    <th width="20%">Category</th>
                    <th width="20%" class="text-center">Technical Details</th>
                    <th width="20%" class="text-right">Value/Qty</th>
                </tr>
            </thead>
            <tbody>
                {% if type == 'reagent' %}
                <tr>
                    <td>
                        <div style="font-weight: bold; font-size: 13px;">{{ reagent.name }}</div>
                        <div style="color: #666; font-size: 9px; margin-top: 3px;">Batch: {{ reagent.batchNumber|default('N/A') }}</div>
                    </td>
                    <td>{{ reagent.categoryName|default('General Reagent') }}</td>
                    <td class="text-center">
                        <div style="font-size: 10px; color: #555;">EXP: {{ reagent.expiryDate|default('N/A') }}</div>
                        <div style="font-size: 10px; color: #555;">PACK: {{ reagent.packSize|default('N/A') }}</div>
                    </td>
                    <td class="text-right">
                        <div style="font-weight: bold; font-size: 13px; color: #2e5aac;">{{ reagent.stock }} Units</div>
                        <div style="color: #666; font-size: 9px;">@ PKR {{ reagent.price|number_format(2) }}</div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td>
                        <div style="font-weight: bold; font-size: 13px;">{{ stockIn.productName }}</div>
                        <div style="color: #666; font-size: 9px; margin-top: 3px;">Supplier: {{ stockIn.supplier|default('N/A') }}</div>
                    </td>
                    <td>Added to Inventory</td>
                    <td class="text-center">
                        <div style="font-size: 10px; color: #555;">Rate: PKR {{ stockIn.unitPrice|number_format(2) }}</div>
                    </td>
                    <td class="text-right">
                        <div style="font-weight: bold; font-size: 13px; color: #27ae60;">+{{ stockIn.quantity }} Units</div>
                        <div style="color: #666; font-size: 9px;">Total Change</div>
                    </td>
                </tr>
                {% endif %}
            </tbody>
        </table>

        {% if type == 'stock_in' %}
        <table class="summary">
            <tr class="total">
                <td>Entry Valuation:</td>
                <td class="text-right">PKR {{ (stockIn.quantity * stockIn.unitPrice)|number_format(2) }}</td>
            </tr>
        </table>
        <div style="clear: both;"></div>
        {% endif %}

    </div>

    <div class="last-page-footer">
        <div style="text-align: center; color: #777; font-size: 10px; font-weight: bold; margin-bottom: 20px;">
            Unique Healthcare Solutions & Laboratory Information System<br>Thank you for your trust in our services!
        </div>

        <div style="text-align: right; padding-right: 50px;">
            <div style="display: inline-block; width: 200px; border-top: 1px solid #000; margin-bottom: 5px; text-align: left;"></div>
            <div style="text-align: right; font-weight: bold; width: 200px; float: right;">Authorized Signature</div>
            <div style="clear: both;"></div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        {% if showHeader %}
        <div style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 6px; font-size: 11px; font-weight: bold; margin-bottom: 8px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 8px;">
            <tr>
                <!-- Address -->
                <td width="20" valign="middle" align="left" style="width: 20px;">
                    <img src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMiIgaGVpZ2h0PSIxMiIgdmlld0JveD0iMCAwIDEyIDEyIj48cGF0aCBkPSJNNiAwQzQgMCAyIDIgMiA0YzAgMyA0IDggNCA4czQtNSA0LThjMC0yLTItNC00LTR6bTAgNmMtMS4xIDAtMi0uOS0yLTJzLjktMiAyLTIgMiAuOSAyIDItLjkgMi0yIDJ6IiBmaWxsPSIjMWIyYTg4Ii8+PC9zdmc+" width="12" height="12" style="display: block; width: 12px; height: 12px;">
                </td>
                <td width="220" valign="middle" style="font-size: 10px; font-weight: bold; text-align: left; padding-left: 10px;">
                    HALI ROAD TEHSIL CHOWK, SAHIWAL PUNJAB PAKISTAN
                </td>
                
                <!-- Phone -->
                <td width="3%" valign="middle" align="center">
                    <span style="color: #1b887a; font-family: DejaVu Sans, sans-serif; font-size: 14px;">&#9742;</span>
                </td>
                <td width="22%" valign="middle" style="font-size: 12px; font-weight: bold; text-align: left; padding-left: 2px;">
                    0312 7171837
                </td>
                
                <!-- Email -->
                <td width="4%" valign="middle" align="right">
                    <span style="color: #c94b26; font-family: DejaVu Sans, sans-serif; font-size: 14px;">&#9993;</span>
                </td>
                <td width="31%" valign="middle" style="font-size: 11px; font-weight: bold; text-align: right; padding-left: 2px;">
                    uniquehealthcaresolution.swl@gmail.com
                </td>
            </tr>
        </table>
        <div style="background-color: #cda34f; color: #000; text-align: center; padding: 4px; font-size: 10px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
        {% endif %}
    </div>
</body>
</html>
