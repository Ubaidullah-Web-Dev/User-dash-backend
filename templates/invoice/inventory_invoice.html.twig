<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Inventory Document - {{ documentNumber }}</title>
    <style>
        body { font-family: DejaVu Sans, Helvetica, Arial, sans-serif; margin: 0; padding: 40px; font-size: 11px; color: #222; line-height: 1.5; }
        .header { margin-bottom: 30px; border-bottom: 2px solid #0ea5e9; padding-bottom: 20px; }
        .header table { width: 100%; border-collapse: collapse; }
        .title { font-size: 28px; font-weight: 900; color: #0ea5e9; text-transform: uppercase; letter-spacing: -1px; }
        .doc-type { font-size: 10px; font-weight: bold; color: #64748b; text-transform: uppercase; letter-spacing: 2px; margin-top: 5px; }
        .meta { text-align: right; }
        .meta-item { margin-bottom: 4px; }
        .meta-label { font-weight: bold; color: #64748b; text-transform: uppercase; font-size: 8px; }
        .meta-value { font-weight: 900; font-size: 12px; color: #0ea5e9; }
        
        .section { margin-bottom: 30px; }
        .section-title { font-size: 9px; font-weight: 900; color: #64748b; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #e2e8f0; padding-bottom: 5px; margin-bottom: 15px; }
        
        .grid { display: table; width: 100%; table-layout: fixed; }
        .col { display: table-cell; vertical-align: top; }
        
        .info-card { background: #f8fafc; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; margin-right: 10px; }
        .info-label { font-size: 8px; font-weight: bold; color: #94a3b8; text-transform: uppercase; margin-bottom: 4px; }
        .info-value { font-size: 11px; font-weight: bold; color: #1e293b; }

        .items-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .items-table th { background: #0ea5e9; color: white; padding: 12px 15px; text-align: left; font-size: 9px; font-weight: 900; text-transform: uppercase; }
        .items-table td { padding: 12px 15px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
        .items-table tr:nth-child(even) { background: #f8fafc; }
        
        .total-section { margin-top: 20px; text-align: right; }
        .total-box { display: inline-block; background: #0ea5e9; color: white; padding: 15px 30px; border-radius: 12px; }
        .total-label { font-size: 9px; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; opacity: 0.8; }
        .total-value { font-size: 20px; font-weight: 900; }

        .footer { margin-top: 60px; text-align: center; color: #94a3b8; font-size: 9px; border-top: 1px solid #f1f5f9; padding-top: 20px; font-weight: 500; }
        .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 8px; font-weight: 900; text-transform: uppercase; }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-info { background: #e0f2fe; color: #0369a1; }
    </style>
</head>
<body>
    <div class="header">
        <table>
            <tr>
                <td>
                    {% if logo %}
                        <img src="{{ logo }}" alt="Logo" style="height: 80px; margin-bottom: 15px;">
                    {% endif %}
                    <div class="title">{{ documentTitle }}</div>
                    <div class="doc-type">Laboratory Inventory Management System</div>
                </td>
                <td class="meta">
                    <div class="meta-item">
                        <span class="meta-label">Ref Number:</span><br/>
                        <span class="meta-value">#{{ documentNumber }}</span>
                    </div>
                    <div class="meta-item" style="margin-top: 10px;">
                        <span class="meta-label">Date:</span><br/>
                        <span class="meta-value" style="color: #64748b; font-size: 10px;">{{ date|date('d M Y, h:i A') }}</span>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Record Details</div>
        <div class="grid">
            <div class="col">
                <div class="info-card">
                    <div class="info-label">Action Performed By</div>
                    <div class="info-value">Lab Administrator</div>
                    <div style="margin-top: 10px;" class="info-label">Organization</div>
                    <div class="info-value">ELECTRO Laboratory</div>
                </div>
            </div>
            <div class="col">
                <div class="info-card" style="margin-right: 0;">
                    <div class="info-label">Action Type</div>
                    <div class="info-value">
                        <span class="badge {{ type == 'stock_in' ? 'badge-success' : 'badge-info' }}">
                            {{ type == 'stock_in' ? 'STOCK REFILL' : (isEditing ? 'METADATA UPDATE' : 'REAGENT REGISTRATION') }}
                        </span>
                    </div>
                    <div style="margin-top: 10px;" class="info-label">Status</div>
                    <div class="info-value">Verified & Recorded</div>
                </div>
            </div>
        </div>
    </div>

    <div class="section">
        <div class="section-title">Itemized Summary</div>
        <table class="items-table">
            <thead>
                <tr>
                    <th width="40%">Item / Reagent</th>
                    <th width="20%">Category</th>
                    <th width="20%" class="text-center">Details</th>
                    <th width="20%" class="text-right">Value/Qty</th>
                </tr>
            </thead>
            <tbody>
                {% if type == 'reagent' %}
                <tr>
                    <td>
                        <div style="font-weight: 900; font-size: 13px;">{{ reagent.name }}</div>
                        <div style="color: #64748b; font-size: 9px; margin-top: 2px;">Batch: {{ reagent.batchNumber|default('N/A') }}</div>
                    </td>
                    <td>{{ reagent.categoryName|default('Uncategorized') }}</td>
                    <td class="text-center">
                        <div style="font-size: 9px; color: #64748b;">EXP: {{ reagent.expiryDate|default('N/A') }}</div>
                        <div style="font-size: 9px; color: #64748b;">SIZE: {{ reagent.packSize|default('N/A') }}</div>
                    </td>
                    <td class="text-right">
                        <div style="font-weight: 900; font-size: 13px;">{{ reagent.stock }} Units</div>
                        <div style="color: #64748b; font-size: 9px;">@ ${{ reagent.price|number_format(2) }}</div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td>
                        <div style="font-weight: 900; font-size: 13px;">{{ stockIn.productName }}</div>
                        <div style="color: #64748b; font-size: 9px; margin-top: 2px;">Supplier: {{ stockIn.supplier|default('N/A') }}</div>
                    </td>
                    <td>Added to Inventory</td>
                    <td class="text-center">
                        <div style="font-size: 9px; color: #64748b;">Rate: ${{ stockIn.unitPrice|number_format(2) }}</div>
                    </td>
                    <td class="text-right">
                        <div style="font-weight: 900; font-size: 13px;">+{{ stockIn.quantity }} Units</div>
                        <div style="color: #64748b; font-size: 9px;">Total Change</div>
                    </td>
                </tr>
                {% endif %}
            </tbody>
        </table>
    </div>

    {% if type == 'stock_in' %}
    <div class="total-section">
        <div class="total-box">
            <div class="total-label">Entry Valuation</div>
            <div class="total-value">${{ (stockIn.quantity * stockIn.unitPrice)|number_format(2) }}</div>
        </div>
    </div>
    {% endif %}

    <div class="footer">
        This is a system-generated document and serve as a formal record of inventory changes in the ELECTRO Laboratory Management System. No physical signature required.
    </div>
</body>
</html>
