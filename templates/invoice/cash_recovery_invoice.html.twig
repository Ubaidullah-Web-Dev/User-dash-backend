<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Payment Receipt - #RECOV-{{ recovery.id }}</title>
    <style>
        @page {
            margin: 130px 30px 140px 30px;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 11px;
            color: #333;
        }

        /* Header (Repeating) */
        .header {
            position: fixed;
            top: -110px;
            left: 0px;
            right: 0px;
            height: 100px;
            border-bottom: 2px solid #cda34f;
        }

        /* Footer (Repeating) */
        .footer {
            position: fixed;
            bottom: -70px;
            left: 0px;
            right: 0px;
            height: 90px;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 28px;
            font-weight: bold;
            color: #2e5aac;
        }

        /* Meta */
        .invoice-meta td {
            padding: 2px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 15px 0;
            clear: both;
        }

        /* Section Title */
        .section-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 5px;
        }

        /* Bil To / Info */
        .info-table {
            line-height: 1.6;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 11px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border: 1px solid #ddd;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td { border-bottom: none; }

        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 18px;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        {% if showHeader %}
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo is defined and logo %}<img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="UHS">{% else %}<div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>{% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #1b2a88; color: #ffffff; display: inline-block; padding: 5px 15px; font-size: 13px; font-weight: bold;">
                        EXCELLENT IN DIAGNOSTIC SERVICES
                    </div>
                </td>
            </tr>
        </table>
        {% endif %}
    </div>

    <div class="container">
        <!-- INFO SECTION (FACE TO FACE) -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <!-- Left Column: Customer Info -->
                <td width="55%" valign="top">
                    <div class="section-title">Received From:</div>
                    <table class="info-table" cellpadding="0" cellspacing="0" border="0">
                        <tr><td style="padding-bottom: 2px;"><strong>Name:</strong></td><td style="padding-left: 10px;">{{ recovery.registeredCustomer.name|upper }}</td></tr>
                        <tr><td style="padding-bottom: 2px;"><strong>Phone:</strong></td><td style="padding-left: 10px;">{{ recovery.registeredCustomer.phone }}</td></tr>
                        {% if recovery.registeredCustomer.labName %}<tr><td><strong>Lab:</strong></td><td style="padding-left: 10px; color: #d69e2e;">{{ recovery.registeredCustomer.labName }}</td></tr>{% endif %}
                    </table>
                </td>

                <!-- Right Column: Receipt Meta -->
                <td width="45%" valign="top" align="right">
                    <div class="invoice-title">Payment Receipt</div>
                    <table class="invoice-meta" align="right">
                        <tr><td><strong>Receipt No:</strong></td><td style="padding-left: 15px;">#RECOV-{{ "%05d"|format(recovery.id) }}</td></tr>
                        <tr><td><strong>Date:</strong></td><td style="padding-left: 15px;">{{ recovery.createdAt|date('d/m/Y h:i A') }}</td></tr>
                        <tr><td><strong>Collector:</strong></td><td style="padding-left: 15px;">{{ invoiceMaker|default('N/A') }}</td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <!-- PAYMENT TABLE -->
        <table class="table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th width="30%" class="text-right">Amount Paid</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <strong>CASH RECOVERY / PENDING BALANCE PAYMENT</strong><br>
                        <span style="font-size:9px;color:#777;">{{ recovery.remarks|default('Partial payment against outstanding balance') }}</span>
                    </td>
                    <td class="text-right" style="font-size: 14px; font-weight: bold;">PKR {{ recovery.amount|number_format(0) }}</td>
                </tr>
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr class="total">
                <td>Net Received:</td>
                <td class="text-right">PKR {{ recovery.amount|number_format(0) }}</td>
            </tr>
            <tr>
                <td>New Outstanding Balance:</td>
                <td class="text-right" style="color: #c0392b; font-weight: bold;">PKR {{ recovery.registeredCustomer.remainingBalance|number_format(0) }}</td>
            </tr>
        </table>
        <div style="clear: both;"></div>

        <div style="margin-top: 50px; text-align: center; color: #777; font-size: 10px; font-style: italic;">
            Note: This is a computer generated receipt and does not require a physical signature for validity.
        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer">
        {% if showHeader %}
        <div style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 6px; font-size: 11px; font-weight: bold; margin-bottom: 8px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 8px;">
            <tr>
                <!-- Address -->
                <td width="20" valign="middle" align="left" style="width: 20px;">
                    <img src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMiIgaGVpZ2h0PSIxMiIgdmlld0JveD0iMCAwIDEyIDEyIj48cGF0aCBkPSJNNiAwQzQgMCAyIDIgMiA0YzAgMyA0IDggNCA4czQtNSA0LThjMC0yLTItNC00LTR6bTAgNmMtMS4xIDAtMi0uOS0yLTJzLjktMiAyLTIgMiAuOSAyIDItLjkgMi0yIDJ6IiBmaWxsPSIjMWIyYTg4Ii8+PC9zdmc+" width="12" height="12" style="display: block; width: 12px; height: 12px;">
                </td>
                <td width="220" valign="middle" style="font-size: 10px; font-weight: bold; text-align: left; padding-left: 10px;">
                    HALI ROAD TEHSIL CHOWK, SAHIWAL PUNJAB PAKISTAN
                </td>
                
                <!-- Phone -->
                <td width="3%" valign="middle" align="center">
                    <span style="color: #1b887a; font-family: DejaVu Sans, sans-serif; font-size: 14px;">&#9742;</span>
                </td>
                <td width="22%" valign="middle" style="font-size: 12px; font-weight: bold; text-align: left; padding-left: 2px;">
                    0312 7171837
                </td>
                
                <!-- Email -->
                <td width="4%" valign="middle" align="right">
                    <span style="color: #c94b26; font-family: DejaVu Sans, sans-serif; font-size: 14px;">&#9993;</span>
                </td>
                <td width="31%" valign="middle" style="font-size: 11px; font-weight: bold; text-align: right; padding-left: 2px;">
                    uniquehealthcaresolution.swl@gmail.com
                </td>
            </tr>
        </table>
        <div style="background-color: #cda34f; color: #000; text-align: center; padding: 4px; font-size: 10px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
        {% endif %}
    </div>

</body>
</html>
