<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Intelligence Report - {{ periodLabel }}</title>
    <style>
        @page {
            margin: 130px 30px 100px 30px;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 11px;
            color: #333;
        }

        /* Header (Repeating) */
        .header {
            position: fixed;
            top: -110px;
            left: 0px;
            right: 0px;
            height: 100px;
            border-bottom: 2px solid #cda34f;
        }

        /* Footer (Repeating) */
        .footer {
            position: fixed;
            bottom: -70px;
            left: 0px;
            right: 0px;
            height: 90px;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 26px;
            font-weight: bold;
            color: #2e5aac;
            letter-spacing: 1px;
        }

        /* Meta */
        .invoice-meta td {
            padding: 2px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 15px 0;
            clear: both;
        }

        /* Section */
        .section-title {
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 10px;
            color: #2e5aac;
        }

        /* Stats Grid */
        .stats-grid { width: 100%; border-collapse: separate; border-spacing: 10px 0; margin: 0 -10px; }
        .stat-card {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 6px;
            border: 1px solid #ddd;
            width: 25%;
            text-align: center;
            vertical-align: top;
        }
        .stat-label { font-size: 9px; font-weight: bold; color: #666; text-transform: uppercase; margin-bottom: 5px; }
        .stat-value { font-size: 15px; font-weight: bold; color: #333; }
        .positive { color: #27ae60; }
        .negative { color: #c0392b; }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 11px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }
        .text-right { text-align: right; }
        
        .footer-note {
            margin-top: 40px; text-align: center; color: #777; font-size: 10px; font-weight: bold;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        {% if showHeader %}
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo is defined and logo %}<img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="UHS">{% else %}<div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>{% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #1b2a88; color: #ffffff; display: inline-block; padding: 5px 15px; font-size: 13px; font-weight: bold;">
                        EXCELLENT IN DIAGNOSTIC SERVICES
                    </div>
                </td>
            </tr>
        </table>
        {% endif %}
    </div>

    <div class="container">
        <!-- HORIZONTAL INFO SECTION -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="55%" valign="top">
                    <div class="section-title">Operational Context:</div>
                    <div style="background-color: #f8f9fa; padding: 12px; border-left: 4px solid #2e5aac; border-radius: 4px;">
                        <div style="font-size: 11px; color: #333; line-height: 1.5;">
                            This document provides a comprehensive high-level analysis of laboratory operations, 
                            financial health, and inventory movements for the specified period.
                        </div>
                    </div>
                </td>
                <td width="45%" valign="top" align="right">
                    <div class="invoice-title">INTELLIGENCE REPORT</div>
                    <table class="invoice-meta" align="right">
                        <tr><td><strong>Report Type:</strong></td><td style="padding-left: 15px;">{{ reportType }} Summary</td></tr>
                        <tr><td><strong>Period:</strong></td><td style="padding-left: 15px; font-weight: bold; color: #2e5aac;">{{ periodLabel }}</td></tr>
                        <tr><td><strong>Generated:</strong></td><td style="padding-left: 15px;">{{ "now"|date('d M Y, h:i A') }}</td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <!-- FINANCIAL MATRIX -->
        <div class="section">
            <div class="section-title">Key Performance Indicators (KPIs)</div>
            <table class="stats-grid">
                <tr>
                    <td class="stat-card">
                        <div class="stat-label">Gross Revenue</div>
                        <div class="stat-value">PKR {{ revenue|number_format(2) }}</div>
                    </td>
                    <td class="stat-card">
                        <div class="stat-label">Lab Expenses</div>
                        <div class="stat-value negative">-{{ labExpenses|number_format(2) }}</div>
                    </td>
                    <td class="stat-card">
                        <div class="stat-label">Net Income</div>
                        <div class="stat-value {{ netIncome >= 0 ? 'positive' : 'negative' }}">
                            {{ netIncome >= 0 ? '+' : '' }}{{ netIncome|number_format(2) }}
                        </div>
                        <div style="font-size: 7px; color: #888; margin-top: 3px;">CASH BASIS</div>
                    </td>
                    <td class="stat-card" style="border-top: 3px solid #c0392b;">
                        <div class="stat-label">Total Pending</div>
                        <div class="stat-value negative">{{ totalPending|number_format(2) }}</div>
                    </td>
                </tr>
            </table>
        </div>

        <!-- OPERATIONAL INSIGHTS -->
        <div class="section">
            <div class="section-title">Operational Insights</div>
            <table class="table">
                <thead>
                    <tr>
                        <th colspan="2">Analytical Metric</th>
                        <th class="text-right">Quantifiable Value</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="font-weight: bold; width: 30%;">Customer Footfall</td>
                        <td>Total unique patient / customer interactions</td>
                        <td class="text-right" style="font-weight: bold;">{{ customerCount }} Count</td>
                    </tr>
                    <tr>
                        <td style="font-weight: bold;">Stock Influx</td>
                        <td>New reagent / product units added to inventory</td>
                        <td class="text-right positive" style="font-weight: bold;">+{{ stockAdded }} Units</td>
                    </tr>
                    <tr>
                        <td style="font-weight: bold;">Stock Consumption</td>
                        <td>Inventory units utilized for sales/orders</td>
                        <td class="text-right negative" style="font-weight: bold;">-{{ stockRemoved }} Units</td>
                    </tr>
                    <tr>
                        <td style="font-weight: bold;">Inventory Delta</td>
                        <td>Net change in physical stock level</td>
                        <td class="text-right" style="font-weight: bold; color: {{ (stockAdded - stockRemoved) >= 0 ? '#27ae60' : '#c0392b' }};">
                            {{ (stockAdded - stockRemoved) >= 0 ? '+' : '' }}{{ stockAdded - stockRemoved }} Units
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="footer-note">
            Unique Healthcare Solutions Management System • Confidential Administrative Document
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        {% if showHeader %}
        <div style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 6px; font-size: 11px; font-weight: bold; margin-bottom: 8px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 8px;">
            <tr>
                <td width="40%" style="font-size: 10px; font-weight: bold;">HALI ROAD TEHSIL CHOWK, SAHIWAL PUNJAB PAKISTAN</td>
                <td width="25%" align="center" style="font-size: 12px; font-weight: bold;">0312 7171837</td>
                <td width="35%" align="right" style="font-size: 11px; font-weight: bold;">uniquehealthcaresolution.swl@gmail.com</td>
            </tr>
        </table>
        <div style="background-color: #cda34f; color: #000; text-align: center; padding: 4px; font-size: 10px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
        {% endif %}
    </div>
</body>
</html>
