<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Lab Intelligence Report - {{ periodLabel }}</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 30px;
            font-size: 11px;
            color: #2d3436;
            background: #fff;
            line-height: 1.4;
        }

        /* Invoice Title Bar */
        .invoice-title-container {
            margin: 20px 0;
            position: relative;
            text-align: center;
        }

        .invoice-title-container::before,
        .invoice-title-container::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 30%;
            height: 12px;
            background-color: #ffc107;
            transform: translateY(-50%);
        }

        .invoice-title-container::before { left: 0; }
        .invoice-title-container::after { right: 0; }

        .invoice-title {
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            display: inline-block;
            padding: 0 20px;
            background: #fff;
            position: relative;
            z-index: 1;
            letter-spacing: 2px;
        }

        .doc-type {
            font-size: 9px;
            font-weight: bold;
            color: #636e72;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 5px;
            text-align: center;
        }

        /* Section */
        .section { margin-bottom: 25px; }
        .section-title {
            font-size: 10px;
            font-weight: bold;
            color: #2d3436;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid #ffc107;
            padding-bottom: 5px;
            margin-bottom: 15px;
        }

        /* Stats Grid */
        .stats-grid { width: 100%; border-collapse: separate; border-spacing: 10px 0; margin: 0 -10px; }
        .stat-card {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 12px;
            border: 1px solid #dfe6e9;
            width: 25%;
            text-align: center;
            vertical-align: top;
        }
        .stat-label { font-size: 8px; font-weight: bold; color: #636e72; text-transform: uppercase; margin-bottom: 5px; }
        .stat-value { font-size: 16px; font-weight: 900; color: #2d3436; }
        .positive { color: #00b894; }
        .negative { color: #d63031; }

        /* Details Table */
        .details-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .details-table th {
            background: #2d3436;
            color: #fff;
            padding: 10px;
            text-align: left;
            font-size: 9px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .details-table td { padding: 12px 10px; border-bottom: 1px solid #dfe6e9; font-size: 11px; }
        .details-table .label { font-weight: bold; color: #636e72; font-size: 9px; text-transform: uppercase; }
        .details-table .value { font-weight: 900; text-align: right; }

        .footer {
            margin-top: 60px;
            text-align: center;
            color: #636e72;
            font-size: 9px;
            border-top: 1px solid #dfe6e9;
            padding-top: 15px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div style="text-align: center; margin: -30px -30px 20px -30px;">
        <img src="{{ absolute_url(asset('images/invoice_header.png')) }}" alt="Header" style="width: 100%; display: block;">
    </div>

    <div class="invoice-title-container">
        <span class="invoice-title">Intelligence Report</span>
    </div>
    <div class="doc-type">{{ reportType }} Analysis Summary • {{ periodLabel }}</div>

    <div class="section" style="margin-top: 30px;">
        <div class="section-title">Financial Performance Matrix</div>
        <table class="stats-grid">
            <tr>
                <td class="stat-card">
                    <div class="stat-label">Gross Revenue</div>
                    <div class="stat-value">PKR {{ revenue|number_format(2) }}</div>
                </td>
                <td class="stat-card">
                    <div class="stat-label">Total Expenses</div>
                    <div class="stat-value negative">-PKR {{ expenses|number_format(2) }}</div>
                </td>
                <td class="stat-card">
                    <div class="stat-label">Net Income</div>
                    <div class="stat-value {{ netIncome >= 0 ? 'positive' : 'negative' }}">
                        {{ netIncome >= 0 ? '+' : '' }}PKR {{ netIncome|number_format(2) }}
                    </div>
                </td>
                <td class="stat-card" style="border-color: #d63031;">
                    <div class="stat-label" style="color: #d63031;">Total Pending</div>
                    <div class="stat-value negative">PKR {{ totalPending|number_format(2) }}</div>
                </td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Operational Data Insights</div>
        <table class="details-table">
            <thead>
                <tr>
                    <th colspan="2">Analytical Metric</th>
                    <th style="text-align: right">Quantifiable Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="label">Customer Footfall</td>
                    <td>Total unique patient / customer interactions</td>
                    <td class="value">{{ customerCount }} Count</td>
                </tr>
                <tr>
                    <td class="label">Stock Influx</td>
                    <td>New reagent / product units added to inventory</td>
                    <td class="value positive">+{{ stockAdded }} Units</td>
                </tr>
                <tr>
                    <td class="label">Stock Consumption</td>
                    <td>Inventory units utilized for sales/orders</td>
                    <td class="value negative">-{{ stockRemoved }} Units</td>
                </tr>
                <tr>
                    <td class="label">Inventory Delta</td>
                    <td>Net change in physical stock level</td>
                    <td class="value" style="color: {{ (stockAdded - stockRemoved) >= 0 ? '#00b894' : '#d63031' }};">
                        {{ (stockAdded - stockRemoved) >= 0 ? '+' : '' }}{{ stockAdded - stockRemoved }} Units
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="footer">
        Generated on {{ dateGenerated|date('d F Y, h:i A') }} • Unique Healthcare Solutions Management System<br>
        Strictly confidential administrative document for internal use only.
    </div>

    <div style="margin: 40px -30px -30px -30px;">
        <img src="{{ absolute_url(asset('images/invoice_footer.png')) }}" alt="Footer" style="width: 100%; display: block;">
    </div>
</body>
</html>
