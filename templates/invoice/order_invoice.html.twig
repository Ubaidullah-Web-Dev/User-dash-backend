<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Invoice - #{{ order.id }}</title>
    <style>
        @page {
            margin: 130px 30px 100px 30px;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 11px;
            color: #333;
        }

        /* Header (Repeating) */
        .header {
            position: fixed;
            top: -110px;
            left: 0px;
            right: 0px;
            height: 100px;
            border-bottom: 2px solid #cda34f;
        }

        /* Footer (Repeating) */
        .footer {
            position: fixed;
            bottom: -70px;
            left: 0px;
            right: 0px;
            height: 90px;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 28px;
            font-weight: bold;
            color: #2e5aac;
        }

        /* Meta */
        .invoice-meta td {
            padding: 2px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 15px 0;
            clear: both;
        }

        /* Section Title */
        .section-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 5px;
        }

        /* Bil To / Info */
        .info-table {
            line-height: 1.6;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 11px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }

        .table tr.order-start td { border-top: 1px solid #ddd; }
        .table tr.order-end td { border-bottom: 1px solid #ddd; }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td { border-bottom: none; }

        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        {% if showHeader %}
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo is defined and logo %}<img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="UHS">{% else %}<div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>{% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #1b2a88; color: #ffffff; display: inline-block; padding: 5px 15px; font-size: 13px; font-weight: bold;">
                        EXCELLENT IN DIAGNOSTIC SERVICES
                    </div>
                </td>
            </tr>
        </table>
        {% endif %}
    </div>

    <div class="container">
        <!-- INFO SECTION (FACE TO FACE) -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <!-- Left Column: Customer Info -->
                <td width="55%" valign="top">
                    <div class="section-title">Customer / Patient:</div>
                    <table class="info-table" cellpadding="0" cellspacing="0" border="0">
                        {% if order.registeredCustomer %}
                        <tr><td style="padding-bottom: 2px;"><strong>Name:</strong></td><td style="padding-left: 10px;">{{ order.registeredCustomer.name|upper }}</td></tr>
                        <tr><td style="padding-bottom: 2px;"><strong>Phone:</strong></td><td style="padding-left: 10px;">{{ order.registeredCustomer.phone }}</td></tr>
                        {% if order.registeredCustomer.labName %}<tr><td><strong>Lab:</strong></td><td style="padding-left: 10px; color: #d69e2e;">{{ order.registeredCustomer.labName }}</td></tr>{% endif %}
                        {% elseif order.guestUser %}
                        <tr><td><strong>Name:</strong></td><td style="padding-left: 10px;">{{ order.guestUser.name|upper }} (GUEST)</td></tr>
                        {% else %}
                        <tr><td><strong>Type:</strong></td><td style="padding-left: 10px;">WALK-IN CUSTOMER</td></tr>
                        {% endif %}
                    </table>
                </td>

                <!-- Right Column: Invoice Meta -->
                <td width="45%" valign="top" align="right">
                    <div class="invoice-title">OFFICIAL RECEIPT</div>
                    <table class="invoice-meta" align="right">
                        <tr><td><strong>Invoice No:</strong></td><td style="padding-left: 15px;">#INV-{{ "%05d"|format(order.id) }}</td></tr>
                        <tr><td><strong>Date:</strong></td><td style="padding-left: 15px;">{{ order.createdAt|date('d/m/Y h:i A') }}</td></tr>
                        <tr><td><strong>Maker:</strong></td><td style="padding-left: 15px;">{{ invoiceMaker|default('N/A') }}</td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <!-- PRODUCTS TABLE -->
        <table class="table">
            <thead>
                <tr><th>Description</th><th width="15%" class="text-right">Price</th><th width="10%" class="text-center">Qty</th><th width="15%" class="text-right">Total</th></tr>
            </thead>
            <tbody>
                {% for item in order.items %}
                <tr class="{% if loop.first %}order-start{% endif %} {% if loop.last %}order-end{% endif %}">
                    <td><strong>{{ item.product.name }}</strong><br><span style="font-size:9px;color:#777;">{{ item.product.category.name|default('General') }}</span>
                        {% if item.discountPercentage > 0 %}<div style="font-size: 8px; color: #c0392b; font-weight: bold;">Disc: {{ item.discountPercentage }}% (-PKR {{ item.discountAmount|number_format(2) }})</div>{% endif %}
                    </td>
                    <td class="text-right">PKR {{ item.price|number_format(2) }}</td>
                    <td class="text-center">{{ item.quantity }}</td>
                    <td class="text-right"><strong>PKR {{ ((item.price * item.quantity) - (item.discountAmount ?? 0))|number_format(2) }}</strong></td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="text-center">No items found.</td></tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr><td>Subtotal:</td><td class="text-right">PKR {{ (order.total + (order.discountAmount ?? 0))|number_format(2) }}</td></tr>
            {% if order.discountAmount > 0 %}
            <tr><td>{{ order.discountPercentage ? 'Discount (' ~ order.discountPercentage ~ '%):' : 'Total Discount:' }}</td><td class="text-right" style="color: #c0392b;">-PKR {{ order.discountAmount|number_format(2) }}</td></tr>
            {% endif %}
            <tr class="total"><td>Grand Total:</td><td class="text-right">PKR {{ order.total|number_format(2) }}</td></tr>
            <tr><td>Amount Paid:</td><td class="text-right">PKR {{ (order.amountTendered ?? 0)|number_format(2) }}</td></tr>
            <tr><td>Balance Due:</td><td class="text-right">
                {% if order.changeDue < 0 %}<span style="color: #c0392b; font-weight: bold;">PKR {{ order.changeDue|abs|number_format(2) }}</span>{% else %}PKR {{ order.changeDue|number_format(2) }}{% endif %}
            </td></tr>
        </table>
        <div style="clear: both;"></div>

        <div style="margin-top: 40px; text-align: center; color: #777; font-size: 10px; font-weight: bold;">
            Unique Healthcare Solutions & Laboratory Information System<br>Thank you for your trust in our services!
        </div>

        <div class="signature" style="margin-top: 40px;">
            <div style="width: 200px; border-top: 1px solid #000; margin-bottom: 5px;"></div>
            Authorized Signature
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        {% if showHeader %}
        <div style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 6px; font-size: 11px; font-weight: bold; margin-bottom: 8px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 8px;">
            <tr>
                <td width="40%" style="font-size: 10px; font-weight: bold;">HALI ROAD TEHSIL CHOWK, SAHIWAL PUNJAB PAKISTAN</td>
                <td width="25%" align="center" style="font-size: 12px; font-weight: bold;">0312 7171837</td>
                <td width="35%" align="right" style="font-size: 11px; font-weight: bold;">uniquehealthcaresolution.swl@gmail.com</td>
            </tr>
        </table>
        <div style="background-color: #cda34f; color: #000; text-align: center; padding: 4px; font-size: 10px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
        {% endif %}
    </div>

</body>
</html>
