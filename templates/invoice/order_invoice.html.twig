<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice - #{{ order.id }}</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 30px;
            font-size: 11px;
            color: #2d3436;
            background: #fff;
            line-height: 1.4;
        }

        /* Invoice Title Bar */
        .invoice-title-container {
            margin: 20px 0;
            position: relative;
            text-align: center;
        }

        .invoice-title-container::before,
        .invoice-title-container::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 38%;
            height: 12px;
            background-color: #ffc107;
            transform: translateY(-50%);
        }

        .invoice-title-container::before {
            left: 0;
        }

        .invoice-title-container::after {
            right: 0;
        }

        .invoice-title {
            font-size: 28px;
            font-weight: bold;
            text-transform: uppercase;
            display: inline-block;
            padding: 0 20px;
            background: #fff;
            position: relative;
            z-index: 1;
            letter-spacing: 2px;
        }

        /* Info Section */
        .info-section {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
        }

        .info-section td {
            vertical-align: top;
            width: 50%;
        }

        .info-label {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 5px;
            text-transform: uppercase;
            color: #636e72;
        }

        .info-value {
            color: #2d3436;
            font-weight: bold;
            font-size: 11px;
        }

        .meta-table {
            float: right;
            border-collapse: collapse;
        }

        .meta-table td {
            padding: 2px 0;
            text-align: right;
        }

        .meta-label {
            font-weight: bold;
            padding-right: 15px;
            color: #636e72;
            text-transform: uppercase;
            font-size: 9px;
        }

        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        .items-table th {
            background: #2d3436;
            color: #fff;
            padding: 10px;
            text-align: left;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 10px;
        }

        .items-table td {
            padding: 10px;
            border-bottom: 1px solid #dfe6e9;
        }

        .items-table tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Summary Section */
        .summary-wrapper {
            width: 100%;
            margin-top: 10px;
        }

        .summary-table {
            width: 250px;
            float: right;
            border-collapse: collapse;
        }

        .summary-table td {
            padding: 4px 8px;
            text-align: right;
        }

        .summary-label {
            font-weight: bold;
            color: #636e72;
            text-transform: uppercase;
            font-size: 9px;
        }

        .summary-value {
            font-weight: bold;
            color: #2d3436;
        }

        .total-row {
            background: #ffc107;
            font-weight: 900;
            font-size: 14px;
        }

        .total-row td {
            padding: 8px;
        }

        .pending-row {
            color: #d63031;
            font-weight: 900;
        }

        /* Badge Area */
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-weight: 900;
            font-size: 10px;
            text-transform: uppercase;
            margin-top: 5px;
        }
        .status-paid { background: #00b894; color: white; }
        .status-pending { background: #d63031; color: white; }

        .footer {
            margin-top: 50px;
            padding-top: 15px;
            border-top: 2px solid #ffc107;
            text-align: center;
            font-size: 9px;
            color: #636e72;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div style="text-align: center; margin: -30px -30px 20px -30px;">
        <img src="{{ absolute_url(asset('images/invoice_header.png')) }}" alt="Header" style="width: 100%; display: block;">
    </div>

    <div class="invoice-title-container">
        <span class="invoice-title">Official Receipt</span>
    </div>

    <table class="info-section">
        <tr>
            <td>
                <div class="info-label">Customer / Patient:</div>
                <div class="info-value">
                    {% if order.registeredCustomer %}
                        {{ order.registeredCustomer.name|upper }}<br>
                        <span style="font-weight: normal; color: #636e72;">{{ order.registeredCustomer.phone }}</span>
                        {% if order.registeredCustomer.labName %}
                            <br><span style="font-weight: normal; font-size: 9px; color: #ffc107;">{{ order.registeredCustomer.labName }}</span>
                        {% endif %}
                    {% elseif order.guestUser %}
                        {{ order.guestUser.name|upper }} (GUEST)
                    {% else %}
                        WALK-IN CUSTOMER
                    {% endif %}
                </div>
            </td>
            <td>
                <table class="meta-table">
                    <tr>
                        <td class="meta-label">Invoice#</td>
                        <td class="info-value">#INV-{{ "%05d"|format(order.id) }}</td>
                    </tr>
                    <tr>
                        <td class="meta-label">Date</td>
                        <td class="info-value">{{ order.createdAt|date('d/m/Y h:i A') }}</td>
                    </tr>
                    <tr>
                        <td class="meta-label">Status</td>
                        <td>
                            {% if order.changeDue < 0 %}
                                <span class="status-badge status-pending">PENDING: PKR {{ (order.changeDue * -1)|number_format(2) }}</span>
                            {% else %}
                                <span class="status-badge status-paid">PAID IN FULL</span>
                            {% endif %}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <table class="items-table">
        <thead>
            <tr>
                <th>Description</th>
                <th width="15%" class="text-right">Price</th>
                <th width="10%" class="text-center">Qty</th>
                <th width="15%" class="text-right">Total</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.items %}
            <tr>
                <td>
                    <div style="font-weight: bold;">{{ item.product.name }}</div>
                    <div style="color: #636e72; font-size: 8px;">{{ item.product.category.name|default('General') }}</div>
                </td>
                <td class="text-right">PKR {{ item.price|number_format(2) }}</td>
                <td class="text-center">{{ item.quantity }}</td>
                <td class="text-right" style="font-weight: bold;">PKR {{ (item.price * item.quantity)|number_format(2) }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="summary-wrapper">
        <table class="summary-table">
            <tr>
                <td class="summary-label">Subtotal</td>
                <td class="summary-value">PKR {{ (order.total + (order.discountAmount ?? 0))|number_format(2) }}</td>
            </tr>
            {% if order.discountAmount > 0 %}
            <tr>
                <td class="summary-label">Discount ({{ order.discountPercentage }}%)</td>
                <td class="summary-value" style="color: #d63031;">-PKR {{ order.discountAmount|number_format(2) }}</td>
            </tr>
            {% endif %}
            <tr class="total-row">
                <td class="summary-label" style="color: #2d3436;">Grand Total</td>
                <td class="summary-value">PKR {{ order.total|number_format(2) }}</td>
            </tr>
            {% if order.previousBalancePayment > 0 %}
            <tr>
                <td class="summary-label" style="padding-top: 5px;">Payment towards Previous Balance</td>
                <td class="summary-value text-emerald-500" style="padding-top: 5px;">PKR {{ order.previousBalancePayment|number_format(2) }}</td>
            </tr>
            {% endif %}
            <tr>
                <td class="summary-label" style="padding-top: 10px;">Amount Paid</td>
                <td class="summary-value" style="padding-top: 10px;">PKR {{ (order.amountTendered ?? 0)|number_format(2) }}</td>
            </tr>
            {% if order.changeDue < 0 %}
            <tr class="pending-row">
                <td class="summary-label" style="color: #d63031;">Pending Amount</td>
                <td class="summary-value">PKR {{ (order.changeDue * -1)|number_format(2) }}</td>
            </tr>
            {% else %}
            <tr>
                <td class="summary-label">Change Due</td>
                <td class="summary-value">PKR {{ (order.changeDue ?? 0)|number_format(2) }}</td>
            </tr>
            {% endif %}
        </table>
        <div style="clear: both;"></div>
    </div>

    <div class="footer">
        Unique Healthcare Solutions & Laboratory Information System<br>
        Thank you for your trust in our services!
    </div>

    <div style="margin: 40px -30px -30px -30px;">
        <img src="{{ absolute_url(asset('images/invoice_footer.png')) }}" alt="Footer" style="width: 100%; display: block;">
    </div>
</body>
</html>
