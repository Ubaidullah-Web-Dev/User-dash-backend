<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice - #{{ order.id }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 12px;
            color: #333;
        }

        .container {
            padding: 30px;
        }

        /* Header/Footer Code Overrides */
        .header {
            margin-bottom: 20px;
        }

        .footer {
            margin-top: 40px;
            font-family: Arial, sans-serif;
            page-break-inside: avoid;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 36px;
            font-weight: bold;
            color: #2e5aac;
            font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
        }

        /* Meta */
        .invoice-meta {
            float: right;
            margin-top: 10px;
        }

        .invoice-meta td {
            padding: 3px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 20px 0;
        }

        /* Section */
        .section {
            margin-top: 10px;
        }

        .section-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 10px;
        }

        /* Bil To / Info */
        .info-table {
            line-height: 1.6;
            margin-bottom: 20px;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 12px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }

        .table tr.order-start td {
            border-top: 1px solid #ddd;
        }

        .table tr.order-end td {
            border-bottom: 1px solid #ddd;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td {
            border-bottom: none;
        }

        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
        
        .badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            color: #fff;
            font-weight: bold;
            font-size: 10px;
        }
        .badge-success { background-color: #27ae60; }
        .badge-danger { background-color: #c0392b; }
    </style>
</head>
<body>

    <!-- HEADER -->
    <div class="header">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo is defined and logo %}
                    <img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="Unique Healthcare Solutions">
                    {% else %}
                    <div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>
                    {% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div
                        style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #cda34f; height: 3px; width: 100%; margin-bottom: 8px;"></div>
                    <table cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td
                                style="background-color: #1b2a88; color: #ffffff; padding: 5px 15px; font-size: 13px; font-weight: bold; font-family: Arial, sans-serif;">
                                EXCELLENT IN DIAGNOSTIC SERVICES
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>

    <div class="container">

        <!-- TITLE -->
        <div class="invoice-title">OFFICIAL RECEIPT</div>

        <!-- META -->
        <table class="invoice-meta">
            <tr>
                <td><strong>Invoice No:</strong></td>
                <td>#INV-{{ "%05d"|format(order.id) }}</td>
            </tr>
            <tr>
                <td><strong>Date:</strong></td>
                <td>{{ order.createdAt|date('d/m/Y h:i A') }}</td>
            </tr>
            <tr>
                <td><strong>Invoice Maker:</strong></td>
                <td>{{ invoiceMaker|default('N/A') }}</td>
            </tr>
        </table>

        <div style="clear: both;"></div>

        <!-- SEPARATOR -->
        <div class="separator"></div>

        <!-- INFO -->
        <div class="section">
            <div class="section-title">Customer / Patient:</div>
            <table class="info-table" cellpadding="0" cellspacing="0" border="0">
                {% if order.registeredCustomer %}
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Name:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ order.registeredCustomer.name|upper }}</td>
                </tr>
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Phone:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ order.registeredCustomer.phone }}</td>
                </tr>
                {% if order.registeredCustomer.labName %}
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Lab Name:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px; color: #d69e2e;">{{ order.registeredCustomer.labName }}</td>
                </tr>
                {% endif %}
                {% elseif order.guestUser %}
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Name:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ order.guestUser.name|upper }} (GUEST)</td>
                </tr>
                {% else %}
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Type:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">WALK-IN CUSTOMER</td>
                </tr>
                {% endif %}
            </table>
        </div>

        <!-- TABLE -->
        <table class="table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th width="15%" class="text-right">Price</th>
                    <th width="10%" class="text-center">Qty</th>
                    <th width="15%" class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                {% for item in order.items %}
                <tr class="{% if loop.first %}order-start{% endif %} {% if loop.last %}order-end{% endif %}">
                    <td>
                        <strong>{{ item.product.name }}</strong><br>
                        <span style="font-size:9px;color:#777;">{{ item.product.category.name|default('General') }}</span>
                        {% if item.discountPercentage > 0 %}
                            <div style="font-size: 8px; color: #c0392b; font-weight: bold; margin-top: 2px;">
                                Discount: {{ item.discountPercentage }}% (-PKR {{ item.discountAmount|number_format(2) }})
                            </div>
                        {% endif %}
                    </td>
                    <td class="text-right">PKR {{ item.price|number_format(2) }}</td>
                    <td class="text-center">{{ item.quantity }}</td>
                    <td class="text-right"><strong>PKR {{ ((item.price * item.quantity) - (item.discountAmount ?? 0))|number_format(2) }}</strong></td>
                </tr>
                {% else %}
                <tr class="order-start order-end">
                    <td colspan="4" class="text-center">No items found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr>
                <td>Subtotal:</td>
                <td class="text-right">
                    PKR {{ (order.total + (order.discountAmount ?? 0))|number_format(2) }}
                </td>
            </tr>
            {% if order.discountAmount > 0 %}
            <tr>
                <td>{{ order.discountPercentage ? 'Discount (' ~ order.discountPercentage ~ '%):' : 'Total Discount:' }}</td>
                <td class="text-right" style="color: #c0392b;">
                    -PKR {{ order.discountAmount|number_format(2) }}
                </td>
            </tr>
            {% endif %}
            <tr class="total">
                <td>Grand Total:</td>
                <td class="text-right">
                    PKR {{ order.total|number_format(2) }}
                </td>
            </tr>
            <tr>
                <td>Amount Paid:</td>
                <td class="text-right">PKR {{ (order.amountTendered ?? 0)|number_format(2) }}</td>
            </tr>
            <tr>
                <td>Change / Balance Due:</td>
                <td class="text-right">
                    {% if order.changeDue < 0 %}
                        <span style="color: #c0392b; font-weight: bold;">PKR {{ order.changeDue|abs|number_format(2) }}</span>
                    {% else %}
                        PKR {{ order.changeDue|number_format(2) }}
                    {% endif %}
                </td>
            </tr>
        </table>

        <div style="clear: both;"></div>

        <div style="margin-top: 40px; text-align: center; color: #777; font-size: 10px; font-weight: bold;">
            Unique Healthcare Solutions & Laboratory Information System<br>
            Thank you for your trust in our services!
        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer">
        <div
            style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 8px; font-size: 13px; font-weight: bold; margin-bottom: 12px; letter-spacing: 0.5px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>

        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 10px;">
            <tr>
                <!-- Location -->
                <td width="40%" valign="middle">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="24" valign="middle">
                                <img src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='%23E53935'%3E%3Cpath d='M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z'/%3E%3C/svg%3E"
                                    alt="Location" width="20" height="20">
                            </td>
                            <td valign="middle"
                                style="font-size: 11px; font-weight: bold; padding-left: 5px; color: #222; line-height: 1.3;">
                                HALI ROAD TEHSIL CHOWK,<br>SAHIWAL PUNJAB PAKISTAN
                            </td>
                        </tr>
                    </table>
                </td>

                <!-- WhatsApp -->
                <td width="25%" valign="middle">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="24" valign="middle">
                                <img src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='%2325D366'%3E%3Cpath d='M12 2.06c-5.5 0-9.96 4.45-9.96 9.94 0 1.76.46 3.48 1.34 5L1.87 22.5l5.65-1.48c1.46.8 3.1 1.22 4.81 1.22 5.5 0 9.96-4.45 9.96-9.94S17.5 2.06 12 2.06zm5.66 14.3c-.24.67-1.37 1.24-1.92 1.32-.51.08-1.17.26-3.32-.64-2.58-1.08-4.24-3.7-4.37-3.88-.13-.17-1.04-1.38-1.04-2.64 0-1.25.65-1.88.89-2.13.23-.25.51-.31.68-.31.17 0 .34 0 .49.01.17.01.38-.05.59.45.21.52.73 1.77.79 1.9.06.13.1.28.01.45-.08.17-.13.27-.26.43-.13.15-.27.33-.39.46-.14.14-.28.29-.12.57.16.27.72 1.18 1.55 1.91 1.07.95 1.96 1.25 2.23 1.38.28.13.44.11.6-.07.17-.18.73-.85.92-1.14.19-.29.38-.24.64-.15.26.1 1.63.77 1.91.91.28.14.47.21.54.33.07.12.07.72-.17 1.39z'/%3E%3C/svg%3E"
                                    alt="WhatsApp" width="20" height="20">
                            </td>
                            <td valign="middle"
                                style="font-size: 13px; font-weight: bold; padding-left: 5px; color: #222;">
                                0312 7171837
                            </td>
                        </tr>
                    </table>
                </td>

                <!-- Email -->
                <td width="35%" valign="middle" align="right">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="24" valign="middle">
                                <img src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='%23EA4335'%3E%3Cpath d='M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z'/%3E%3C/svg%3E"
                                    alt="Email" width="20" height="20">
                            </td>
                            <td valign="middle"
                                style="font-size: 12px; font-weight: bold; padding-left: 5px; color: #222;">
                                uniquehealthcaresolution.swl@gmail.com
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <div
            style="background-color: #cda34f; color: #000; text-align: center; padding: 6px; font-size: 11px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
    </div>

</body>
</html>
