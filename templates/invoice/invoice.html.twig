<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>{{ poNumber }}</title>
    <style>
        @page {
            margin: 130px 30px 100px 30px;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 11px;
            color: #333;
        }

        /* Header (Repeating) */
        .header {
            position: fixed;
            top: -110px;
            left: 0px;
            right: 0px;
            height: 100px;
            border-bottom: 2px solid #cda34f;
        }

        /* Footer (Repeating) */
        .footer {
            position: fixed;
            bottom: -70px;
            left: 0px;
            right: 0px;
            height: 90px;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 28px;
            font-weight: bold;
            color: #2e5aac;
            text-transform: uppercase;
        }

        /* Meta */
        .invoice-meta td {
            padding: 2px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 15px 0;
            clear: both;
        }

        /* Section */
        .section-title {
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 5px;
            color: #2e5aac;
        }

        /* Info Boxes */
        .info-box {
            padding: 10px;
            background-color: #f8f9fa;
            border: 1px solid #ddd;
            border-radius: 4px;
            min-height: 100px;
        }

        .info-box h2 {
            margin: 0 0 5px 0;
            font-size: 12px;
            color: #333;
        }

        .info-box p {
            margin: 0 0 2px 0;
            font-size: 10px;
            color: #555;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 11px;
            text-align: left;
            text-transform: uppercase;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
            border-bottom: 1px solid #ddd;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td { border-bottom: none; }

        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }

        .badge { display: inline-block; padding: 4px 10px; border-radius: 4px; font-size: 9px; font-weight: bold; text-transform: uppercase; }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-danger { background: #fee2e2; color: #991b1b; }

        .footer-note {
            margin-top: 40px; text-align: center; color: #777; font-size: 10px; font-weight: bold;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        {% if showHeader %}
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo is defined and logo %}<img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="UHS">{% else %}<div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>{% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #1b2a88; color: #ffffff; display: inline-block; padding: 5px 15px; font-size: 13px; font-weight: bold;">
                        EXCELLENT IN DIAGNOSTIC SERVICES
                    </div>
                </td>
            </tr>
        </table>
        {% endif %}
    </div>

    <div class="container">
        <!-- HORIZONTAL INFO SECTION -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="55%" valign="top">
                    <!-- TWO BOX LAYOUT WITHIN THE COLUMN -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="48%" valign="top">
                                <div class="section-title">From:</div>
                                <div class="info-box">
                                    {% if type == 'seller' %}
                                    <h2>UNIQUE HEALTHCARE SOLUTIONS</h2>
                                    <p>Alphasoft360</p>
                                    <p>Sahiwal, Punjab, Pakistan</p>
                                    <p>billing@uniquehealthcare.com</p>
                                    {% else %}
                                    <h2>{{ vendor.name|upper }}</h2>
                                    <p>{{ vendor.address }}</p>
                                    {% if vendor.email %}<p>{{ vendor.email }}</p>{% endif %}
                                    {% if vendor.phone %}<p>{{ vendor.phone }}</p>{% endif %}
                                    {% endif %}
                                </div>
                            </td>
                            <td width="4%"></td>
                            <td width="48%" valign="top">
                                <div class="section-title">To:</div>
                                <div class="info-box">
                                    {% if type == 'seller' %}
                                    <h2>{{ customer.name|upper }}</h2>
                                    <p>{{ customer.address }}</p>
                                    <p>Ph: {{ customer.phone }}</p>
                                    {% if customer.email %}<p>{{ customer.email }}</p>{% endif %}
                                    {% else %}
                                    <h2>UNIQUE HEALTHCARE SOLUTIONS</h2>
                                    <p>Alphasoft360</p>
                                    <p>Sahiwal, Punjab, Pakistan</p>
                                    <p>warehouse@uniquehealthcare.com</p>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    </table>
                </td>
                <td width="45%" valign="top" align="right">
                    <div class="invoice-title">{{ type == 'buyer' ? 'SUPPLY ORDER' : 'PURCHASE ORDER' }}</div>
                    <table class="invoice-meta" align="right">
                        <tr><td><strong>Order No:</strong></td><td style="padding-left: 15px; font-weight: bold; color: #2e5aac;">#{{ poNumber }}</td></tr>
                        <tr><td><strong>Date:</strong></td><td style="padding-left: 15px;">{{ date|date('M d, Y') }}</td></tr>
                        <tr><td><strong>Maker:</strong></td><td style="padding-left: 15px;">{{ invoiceMaker|default('N/A') }}</td></tr>
                        <tr><td><strong>Terms:</strong></td><td style="padding-left: 15px;">DUE ON RECEIPT</td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <!-- ITEMS TABLE -->
        <table class="table">
            <thead>
                <tr>
                    <th width="5%" class="text-center">#</th>
                    <th>Description</th>
                    <th width="10%" class="text-center">Qty</th>
                    <th width="20%" class="text-right">Rate</th>
                    <th width="20%" class="text-right">Amount</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>
                    <td class="text-center">{{ loop.index }}</td>
                    <td style="font-weight: bold;">
                        {{ item.description }}
                        {% if item.discountPercentage is defined and item.discountPercentage > 0 %}
                        <div style="font-size: 8px; color: #c0392b; font-weight: bold;">Disc: {{ item.discountPercentage }}% (-PKR {{ item.discountAmount|number_format(2) }})</div>
                        {% endif %}
                    </td>
                    <td class="text-center">{{ item.qty }}</td>
                    <td class="text-right">PKR {{ item.rate|number_format(2) }}</td>
                    <td class="text-right" style="font-weight: bold;">PKR {{ item.amount|number_format(2) }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr><td>Subtotal:</td><td class="text-right">PKR {{ subtotal|number_format(2) }}</td></tr>
            {% if discountAmount is defined and discountAmount > 0 %}
            <tr><td>{{ discountPercentage is defined and discountPercentage ? 'Discount (' ~ discountPercentage ~ '%):' : 'Total Discount:' }}</td><td class="text-right" style="color: #c0392b;">-PKR {{ discountAmount|number_format(2) }}</td></tr>
            {% endif %}
            <tr class="total"><td>Total Amount:</td><td class="text-right">PKR {{ total|number_format(2) }}</td></tr>
            
            {% if amountTendered is defined and amountTendered is not null %}
            <tr><td>Cash Paid:</td><td class="text-right">PKR {{ amountTendered|number_format(2) }}</td></tr>
            <tr>
                {% if changeDue < 0 %}
                <td style="color: #c0392b; font-weight: bold;">Outstanding:</td>
                <td class="text-right" style="color: #c0392b; font-weight: bold;">PKR {{ changeDue|abs|number_format(2) }}</td>
                {% else %}
                <td>Change Due:</td>
                <td class="text-right">PKR {{ changeDue|number_format(2) }}</td>
                {% endif %}
            </tr>
            <tr style="background-color: #f8f9fa;">
                <td style="font-weight: bold;">Payment Status:</td>
                <td class="text-right">
                    {% if changeDue < 0 %}<span class="badge badge-danger">PARTIAL</span>{% else %}<span class="badge badge-success">PAID</span>{% endif %}
                </td>
            </tr>
            {% endif %}
        </table>
        
        <div style="clear: both;"></div>
        <div class="footer-note">Electronically generated by Unique Healthcare Solutions</div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        {% if showHeader %}
        <div style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 6px; font-size: 11px; font-weight: bold; margin-bottom: 8px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 8px;">
            <tr>
                <td width="40%" style="font-size: 10px; font-weight: bold;">HALI ROAD TEHSIL CHOWK, SAHIWAL PUNJAB PAKISTAN</td>
                <td width="25%" align="center" style="font-size: 12px; font-weight: bold;">0312 7171837</td>
                <td width="35%" align="right" style="font-size: 11px; font-weight: bold;">uniquehealthcaresolution.swl@gmail.com</td>
            </tr>
        </table>
        <div style="background-color: #cda34f; color: #000; text-align: center; padding: 4px; font-size: 10px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
        {% endif %}
    </div>
</body>
</html>