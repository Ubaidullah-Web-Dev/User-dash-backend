<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Invoice - {{ customer.name }}</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 12px;
            color: #333;
        }

        .container {
            padding: 30px;
        }

        /* Header */
        .header img {
            width: 100%;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 36px;
            font-weight: bold;
            color: #2e5aac;
        }

        /* Meta */
        .invoice-meta {
            float: right;
            margin-top: 10px;
        }

        .invoice-meta td {
            padding: 3px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 20px 0;
        }

        /* Section */
        .section {
            margin-top: 10px;
        }

        .section-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 10px;
        }

        /* Bill To */
        .bill-to {
            line-height: 1.6;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 12px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }
        
        .table tr.order-start td {
            border-top: 1px solid #ddd;
        }
        
        .table tr.order-end td {
            border-bottom: 1px solid #ddd;
        }

        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td {
            border-bottom: none;
        }

        /* Highlight total */
        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }

        /* Discount row styling */
        .summary .discount {
            background: #f8f9fa;
        }

        /* Footer */
        .footer img {
            width: 100%;
            margin-top: 40px;
        }

        /* Signature */
        .signature {
            margin-top: 80px;
        }

        .signature-line {
            width: 200px;
            border-top: 1px solid #000;
            margin-bottom: 5px;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        <img src="{{ absolute_url(asset('images/invoice_header.png')) }}">
    </div>

    <div class="container">

        <!-- TITLE -->
        <div class="invoice-title">INVOICE</div>

        <!-- META -->
        <table class="invoice-meta">
            <tr>
                <td><strong>Invoice No:</strong></td>
                <td>{{ periodLabel|default('INV-' ~ "now"|date("Ymd")) }}</td>
            </tr>
            <tr>
                <td><strong>Date:</strong></td>
                <td>{{ date|date('d-m-Y') }}</td>
            </tr>
            <tr>
                <td><strong>Due Date:</strong></td>
                <td>-</td>
            </tr>
        </table>

        <div style="clear: both;"></div>

        <!-- SEPARATOR (matches image 1) -->
        <div class="separator"></div>

        <!-- BILL TO -->
        <div class="section">
            <div class="section-title">Bill To:</div>
            <div class="bill-to">
                <strong>{{ customer.name }}</strong><br>
                {{ customer.address|default('No Address Provided') }}<br>
                {{ customer.city|default('N/A') }}<br>
                Phone: {{ customer.phone }}
            </div>
        </div>

        <!-- TABLE -->
        <table class="table">
            <thead>
                <tr>
                    <th width="5%">Sr</th>
                    <th>Item Name</th>
                    <th>Description</th>
                    <th width="10%">Qty</th>
                    <th width="15%">Unit Price</th>
                    <th width="15%">Total</th>
                </tr>
            </thead>

            <tbody>
                {% set sr = 1 %}
                {% for order in orders %}
                    {% for item in order.items %}
                    <tr class="{% if loop.first %}order-start{% endif %} {% if loop.last %}order-end{% endif %}">
                        <td class="text-center">{% if loop.first %}{{ sr }}{% endif %}</td>

                        <td>
                            <strong>{{ item.name }}</strong><br>
                            <span style="font-size:9px;color:#777;">(Order #{{ order.orderId }})</span>
                        </td>

                        <td>
                            {{ item.description }}
                            {% if loop.last and order.pending > 0 %}
                            <div style="color:red; font-size:10px; margin-top:5px;">
                                Pending: PKR {{ order.pending|number_format(2) }}
                            </div>
                            {% endif %}
                        </td>

                        <td class="text-center">{{ item.quantity }}</td>

                        <td class="text-right">
                            PKR {{ item.price|number_format(2) }}
                        </td>

                        <td class="text-right">
                            PKR {{ item.total|number_format(2) }}
                        </td>
                    </tr>
                    {% endfor %}
                    {% set sr = sr + 1 %}
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">
                        No activity recorded for this period.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr>
                <td>Subtotal:</td>
                <td class="text-right">
                    PKR {{ totalSpent|number_format(2) }}
                </td>
            </tr>

            <tr class="total">
                <td>Grand Total:</td>
                <td class="text-right">
                    PKR {{ totalSpent|number_format(2) }}
                </td>
            </tr>
        </table>

        <div style="clear: both;"></div>

        <!-- BALANCE -->
        {% if customerRemainingBalance is defined and customerRemainingBalance > 0 %}
        <div style="margin-top: 10px; text-align: right; color: red; font-weight: bold;">
            Outstanding Balance: PKR {{ customerRemainingBalance|number_format(2) }}
        </div>
        {% endif %}

        <!-- SIGNATURE -->
        <div class="signature">
            <div class="signature-line"></div>
            Authorized Signature
        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer">
        <img src="{{ absolute_url(asset('images/invoice_footer.png')) }}">
    </div>

</body>

</html>