<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Invoice - {{ customer.name }}</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 30px;
            font-size: 12px;
            color: #2d3436;
            background: #fff;
        }

        /* Header Section */
        .header-top {
            display: table;
            width: 100%;
            margin-bottom: 20px;
        }

        .header-left {
            display: table-cell;
            vertical-align: middle;
        }

        .brand-logo {
            float: left;
            margin-right: 15px;
        }

        .brand-name {
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 0;
            line-height: 1;
        }

        .brand-tagline {
            font-size: 10px;
            color: #636e72;
            letter-spacing: 1px;
            margin-top: 5px;
        }

        /* Invoice Title Bar */
        .invoice-title-container {
            margin: 20px 0;
            position: relative;
            text-align: center;
        }

        .invoice-title-container::before,
        .invoice-title-container::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 38%;
            height: 12px;
            background-color: #ffc107;
            transform: translateY(-50%);
        }

        .invoice-title-container::before {
            left: 0;
        }

        .invoice-title-container::after {
            right: 0;
        }

        .invoice-title {
            font-size: 32px;
            font-weight: bold;
            text-transform: uppercase;
            display: inline-block;
            padding: 0 20px;
            background: #fff;
            position: relative;
            z-index: 1;
            letter-spacing: 2px;
        }

        /* Info Section */
        .info-section {
            width: 100%;
            margin-bottom: 30px;
            border-collapse: collapse;
        }

        .info-section td {
            vertical-align: top;
            width: 50%;
        }

        .info-label {
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 10px;
        }

        .info-value {
            color: #2d3436;
            line-height: 1.4;
        }

        .meta-table {
            float: right;
            border-collapse: collapse;
        }

        .meta-table td {
            padding: 2px 0;
            text-align: right;
        }

        .meta-label {
            font-weight: bold;
            padding-right: 20px;
        }

        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        .items-table th {
            background: #2d3436;
            color: #fff;
            padding: 10px;
            text-align: left;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 11px;
        }

        .items-table td {
            padding: 12px 10px;
            border-bottom: 1px solid #dfe6e9;
        }

        .items-table tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        /* Summary Section */
        .summary-container {
            width: 100%;
            border-collapse: collapse;
        }

        .summary-container td {
            vertical-align: top;
        }

        .footer-note {
            width: 60%;
            padding-top: 20px;
        }

        .summary-table {
            width: 100%;
            border-collapse: collapse;
        }

        .summary-table td {
            padding: 5px 10px;
            text-align: right;
        }

        .summary-row-total {
            background: #ffc107;
            font-weight: bold;
            font-size: 16px;
        }

        .summary-row-total td {
            padding: 10px;
        }

        /* Terms & Payment Info */
        .details-box {
            margin-top: 20px;
            font-size: 10px;
        }

        .details-title {
            font-weight: bold;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        /* Signature */
        .signature-area {
            text-align: right;
            margin-top: 40px;
        }

        .signature-line {
            border-top: 1px solid #2d3436;
            width: 150px;
            display: inline-block;
            margin-bottom: 5px;
        }

        .signature-label {
            font-weight: bold;
        }

        /* Contact Footer */
        .contact-footer {
            margin-top: 50px;
            border-top: 2px solid #ffc107;
            padding-top: 10px;
            text-align: center;
            font-weight: bold;
            font-size: 10px;
        }

        .contact-item {
            display: inline-block;
            padding: 0 15px;
            border-right: 1px solid #dfe6e9;
        }

        .contact-item:last-child {
            border-right: none;
        }
    </style>
</head>

<body>
    <div style="text-align: center; margin: -30px -30px 20px -30px;">
        <img src="{{ absolute_url(asset('images/invoice_header.png')) }}" alt="Header" style="width: 100%; display: block;">
    </div>

    <div class="header-top">
        <div class="header-left">
            {% if logo %}
            <img src="{{ logo }}" alt="Logo" class="brand-logo" style="height: 50px;">
            {% else %}
            <div class="brand-logo"
                style="width: 50px; height: 50px; background: #2d3436; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white;">
                <span style="font-size: 20px; font-weight: 900;">UH</span>
            </div>
            {% endif %}
            <h1 class="brand-name">Unique Healthcare</h1>
            <div class="brand-tagline">Solutions for a Better Life</div>
        </div>
    </div>

    <div class="invoice-title-container">
        <span class="invoice-title">INVOICE</span>
    </div>

    <table class="info-section">
        <tr>
            <td>
                <div style="margin-bottom: 8px;">
                    <span class="info-label" style="text-transform: capitalize;">Invoice to:</span>
                    <strong style="font-size: 14px; margin-left: 5px;">{{ customer.name|upper }}</strong>
                </div>
                <div class="info-value">
                    <span style="font-weight: bold;">Address:</span> <span style="color: #636e72;">{{
                        customer.address|default('No Address Provided') }}</span><br>
                    <span style="font-weight: bold;">City:</span> <span style="color: #636e72;">{{
                        customer.city|default('N/A') }}</span><br>
                    <span style="font-weight: bold;">Phone:</span> <span style="color: #636e72;">{{ customer.phone
                        }}</span>
                </div>
            </td>
            <td>
                <div style="float: right;">
                    <table class="meta-table">
                        <tr>
                            <td class="meta-label">Invoice#</td>
                            <td>{{ periodLabel|default('INV-' ~ "now"|date("Ymd")) }}</td>
                        </tr>
                        <tr>
                            <td class="meta-label">Date</td>
                            <td>{{ date|date('d / m / Y') }}</td>
                        </tr>
                    </table>
                </div>
            </td>
        </tr>
    </table>

    <table class="items-table">
        <thead>
            <tr>
                <th width="5%" class="text-center">SL.</th>
                <th>Item Description</th>
                <th width="15%" class="text-right">Price</th>
                <th width="10%" class="text-center">Qty.</th>
                <th width="15%" class="text-right">Total</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
            <tr>
                <td class="text-center">{{ loop.index }}</td>
                <td>
                    <div style="margin-bottom: 2px;">
                        <strong>Order #{{ order.orderId }}</strong>
                        <span style="font-size: 10px; color: #636e72; margin-left: 10px;">{{ order.date|date('d M Y')
                            }}</span>
                    </div>
                    <div style="font-size: 10px; color: #636e72;">{{ order.products }}</div>
                    {% if order.discountAmount > 0 %}
                    <div style="font-size: 9px; color: #00b894; margin-top: 2px;">
                        Discount Applied: -PKR {{ order.discountAmount|number_format(2) }} ({{ order.discountPercentage
                        }}%)
                    </div>
                    {% endif %}
                    {% if order.pending > 0 %}
                    <div style="font-size: 9px; color: #d63031;">
                        Pending: PKR {{ order.pending|number_format(2) }}
                    </div>
                    {% endif %}
                </td>
                <td class="text-right">PKR {{ order.total|number_format(2) }}</td>
                <td class="text-center">1</td>
                <td class="text-right">PKR {{ order.total|number_format(2) }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" style="text-align: center; padding: 40px; color: #b2bec3; font-style: italic;">
                    No activity recorded for this period.
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="summary-container">
        <tr>
            <td class="footer-note">
                <div style="font-weight: bold; margin-bottom: 10px;">Thank you for your business</div>

                <div class="details-box">
                    <div class="details-title">Terms & Conditions</div>
                    <div style="color: #636e72;">
                        Payment is due within 30 days. Please make checks payable to Unique Healthcare Solutions.
                    </div>
                </div>

                <div class="details-box">
                    <div class="details-title">Payment Info:</div>
                    <div style="color: #636e72;">
                        A/C Name: Unique Healthcare Solutions
                    </div>
                </div>
            </td>
            <td width="35%">
                <table class="summary-table">
                    <tr>
                        <td class="meta-label">Sub Total:</td>
                        <td>PKR {{ totalSpent|number_format(2) }}</td>
                    </tr>
                    <tr class="summary-row-total">
                        <td class="meta-label">Total:</td>
                        <td>PKR {{ totalSpent|number_format(2) }}</td>
                    </tr>
                </table>

                {% if customerRemainingBalance is defined and customerRemainingBalance > 0 %}
                <div style="margin-top: 10px; text-align: right; color: #d63031; font-weight: bold;">
                    Outstanding Balance: PKR {{ customerRemainingBalance|number_format(2) }}
                </div>
                {% endif %}
            </td>
        </tr>
    </table>

    <div class="contact-footer">
        <span class="contact-item">Phone # : {{ customer.phone }}</span>
        <span class="contact-item">Address : {{ customer.address|default('Your Company Address') }}</span>
        <span class="contact-item">Website : https://apps.alphasoft360.org/unique-healthcare-solutions</span>
    </div>

    <div style="margin: 40px -30px -30px -30px;">
        <img src="{{ absolute_url(asset('images/invoice_footer.png')) }}" alt="Footer" style="width: 100%; display: block;">
    </div>
</body>

</html>
