<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Ledger - {{ customer.name }}</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 12px;
            color: #333;
        }

        .container {
            padding: 30px;
        }

        /* Header */
        .header img {
            width: 100%;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 36px;
            font-weight: bold;
            color: #2e5aac;
        }

        /* Meta */
        .invoice-meta {
            float: right;
            margin-top: 10px;
        }

        .invoice-meta td {
            padding: 3px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 20px 0;
        }

        /* Section */
        .section {
            margin-top: 10px;
        }

        .section-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 10px;
        }

        /* Bill To */
        .bill-to {
            line-height: 1.6;
        }

        /* Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 12px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }

        .table tr.order-start td {
            border-top: 1px solid #ddd;
        }

        .table tr.order-end td {
            border-bottom: 1px solid #ddd;
        }

        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td {
            border-bottom: none;
        }

        /* Highlight total */
        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }

        /* Discount row styling */
        .summary .discount {
            background: #f8f9fa;
        }

        /* Header/Footer Code Overrides */
        .header {
            margin-bottom: 20px;
        }

        .footer {
            margin-top: 40px;
            font-family: Arial, sans-serif;
            page-break-inside: avoid;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo %}
                    <img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="Unique Healthcare Solutions">
                    {% else %}
                    <div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>
                    {% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div
                        style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #cda34f; height: 3px; width: 100%; margin-bottom: 8px;"></div>
                    <table cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td
                                style="background-color: #1b2a88; color: #ffffff; padding: 5px 15px; font-size: 13px; font-weight: bold; font-family: Arial, sans-serif;">
                                EXCELLENT IN DIAGNOSTIC SERVICES
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>

    <div class="container">

        <!-- TITLE -->
        <div class="invoice-title" style="font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;">
            LEDGER</div>

        <!-- META -->
        <table class="invoice-meta">
            <tr>
                <td><strong>Ledger No:</strong></td>
                <td>{{ statementNumber|default('STMT-' ~ "now"|date("Ymd")) }}</td>
            </tr>
            <tr>
                <td><strong>Timeline:</strong></td>
                <td>{{ periodLabel|default('All Time') }}</td>
            </tr>
            <tr>
                <td><strong>Date:</strong></td>
                <td>{{ date|date('d-m-Y') }}</td>
            </tr>
        </table>

        <div style="clear: both;"></div>

        <!-- SEPARATOR (matches image 1) -->
        <div class="separator"></div>

        <!-- BILL TO -->
        <div class="section">
            <div class="section-title">Bill To:</div>
            <table class="bill-to" cellpadding="0" cellspacing="0" border="0">
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Name:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ customer.name }}</td>
                </tr>
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Address:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ customer.address|default('No Address
                        Provided') }}</td>
                </tr>
                <tr>
                    <td style="padding-bottom: 3px;"><strong>City:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ customer.city|default('N/A') }}</td>
                </tr>
                <tr>
                    <td style="padding-bottom: 3px;"><strong>Phone:</strong></td>
                    <td style="padding-bottom: 3px; padding-left: 10px;">{{ customer.phone }}</td>
                </tr>
            </table>
        </div>

        <!-- TABLE -->
        <table class="table">
            <thead>
                <tr>
                    <th width="5%">Sr</th>
                    <th>Item Name</th>
                    <th>Description</th>
                    <th width="10%">Qty</th>
                    <th width="15%">Unit Price</th>
                    <th width="15%">Total</th>
                </tr>
            </thead>

            <tbody>
                {% set sr = 1 %}
                {% for order in orders %}
                {% for item in order.items %}
                <tr class="{% if loop.first %}order-start{% endif %} {% if loop.last %}order-end{% endif %}">
                    <td class="text-center">{% if loop.first %}{{ sr }}{% endif %}</td>

                    <td>
                        <strong>{{ item.name }}</strong><br>
                        <span style="font-size:9px;color:#777;">(Order #{{ order.orderId }} - {{ order.date|date('d-m-Y') }})</span>
                    </td>

                    <td>
                        {{ item.description }}
                        {% if item.discountPercentage > 0 %}
                            <div style="color: #c0392b; font-size: 9px; margin-top: 2px; font-weight: bold;">
                                Item Discount: {{ item.discountPercentage }}% (-PKR {{ item.discountAmount|number_format(2) }})
                            </div>
                        {% endif %}
                        
                        {% if loop.last %}
                            {% if order.discountAmount > 0 and not item.discountPercentage %}
                            <div style="color:green; font-size:10px; margin-top:5px;">
                                Discount: {{ order.discountPercentage }}% (PKR {{ order.discountAmount|number_format(2) }})
                            </div>
                            {% endif %}
                            
                            {% if order.pending > 0 %}
                            <div style="color:red; font-size:10px; margin-top:2px;">
                                Pending: PKR {{ order.pending|number_format(2) }}
                            </div>
                            {% endif %}
                        {% endif %}
                    </td>

                    <td class="text-center">{{ item.quantity }}</td>

                    <td class="text-right">
                        PKR {{ item.price|number_format(2) }}
                    </td>

                    <td class="text-right">
                        PKR {{ item.total|number_format(2) }}
                    </td>
                </tr>
                {% endfor %}
                {% set sr = sr + 1 %}
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">
                        No activity recorded for this period.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr>
                <td>Subtotal:</td>
                <td class="text-right">
                    PKR {{ subTotal|number_format(2) }}
                </td>
            </tr>

            {% if totalDiscount > 0 %}
            <tr class="discount">
                <td>Total Discount:</td>
                <td class="text-right">
                    - PKR {{ totalDiscount|number_format(2) }}
                </td>
            </tr>
            {% endif %}

            <tr class="total">
                <td>Grand Total:</td>
                <td class="text-right">
                    PKR {{ totalSpent|number_format(2) }}
                </td>
            </tr>
        </table>

        <div style="clear: both;"></div>

        <!-- BALANCE -->
        {% if customerRemainingBalance is defined and customerRemainingBalance > 0 %}
        <div style="margin-top: 10px; text-align: right; color: red; font-weight: bold;">
            Outstanding Balance: PKR {{ customerRemainingBalance|number_format(2) }}
        </div>
        {% endif %}

        <!-- SIGNATURE -->
        <div class="signature" style="margin-top: 80px;">
            <div class="signature-line" style="width: 200px; border-top: 1px solid #000; margin-bottom: 5px;"></div>
            Authorized Signature
        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer">
        <div
            style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 8px; font-size: 13px; font-weight: bold; margin-bottom: 12px; letter-spacing: 0.5px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>

        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 10px;">
            <tr>
                <!-- Location -->
                <td width="40%" valign="middle">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="24" valign="middle">
                                <img src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='%23E53935'%3E%3Cpath d='M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z'/%3E%3C/svg%3E"
                                    alt="Location" width="20" height="20">
                            </td>
                            <td valign="middle"
                                style="font-size: 11px; font-weight: bold; padding-left: 5px; color: #222; line-height: 1.3;">
                                HALI ROAD TEHSIL CHOWK,<br>SAHIWAL PUNJAB PAKISTAN
                            </td>
                        </tr>
                    </table>
                </td>

                <!-- WhatsApp -->
                <td width="25%" valign="middle">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="24" valign="middle">
                                <img src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='%2325D366'%3E%3Cpath d='M12 2.06c-5.5 0-9.96 4.45-9.96 9.94 0 1.76.46 3.48 1.34 5L1.87 22.5l5.65-1.48c1.46.8 3.1 1.22 4.81 1.22 5.5 0 9.96-4.45 9.96-9.94S17.5 2.06 12 2.06zm5.66 14.3c-.24.67-1.37 1.24-1.92 1.32-.51.08-1.17.26-3.32-.64-2.58-1.08-4.24-3.7-4.37-3.88-.13-.17-1.04-1.38-1.04-2.64 0-1.25.65-1.88.89-2.13.23-.25.51-.31.68-.31.17 0 .34 0 .49.01.17.01.38-.05.59.45.21.52.73 1.77.79 1.9.06.13.1.28.01.45-.08.17-.13.27-.26.43-.13.15-.27.33-.39.46-.14.14-.28.29-.12.57.16.27.72 1.18 1.55 1.91 1.07.95 1.96 1.25 2.23 1.38.28.13.44.11.6-.07.17-.18.73-.85.92-1.14.19-.29.38-.24.64-.15.26.1 1.63.77 1.91.91.28.14.47.21.54.33.07.12.07.72-.17 1.39z'/%3E%3C/svg%3E"
                                    alt="WhatsApp" width="20" height="20">
                            </td>
                            <td valign="middle"
                                style="font-size: 13px; font-weight: bold; padding-left: 5px; color: #222;">
                                0312 7171837
                            </td>
                        </tr>
                    </table>
                </td>

                <!-- Email -->
                <td width="35%" valign="middle" align="right">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td width="24" valign="middle">
                                <img src="data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='%23EA4335'%3E%3Cpath d='M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z'/%3E%3C/svg%3E"
                                    alt="Email" width="20" height="20">
                            </td>
                            <td valign="middle"
                                style="font-size: 12px; font-weight: bold; padding-left: 5px; color: #222;">
                                uniquehealthcaresolution.swl@gmail.com
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <div
            style="background-color: #cda34f; color: #000; text-align: center; padding: 6px; font-size: 11px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
    </div>

</body>

</html>