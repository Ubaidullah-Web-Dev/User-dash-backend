<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Ledger - {{ customer.name }}</title>

    <style>
        @page {
            margin: 130px 30px 100px 30px;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            font-size: 11px;
            color: #333;
        }

        /* Header (Repeating) */
        .header {
            position: fixed;
            top: -110px;
            left: 0px;
            right: 0px;
            height: 100px;
            border-bottom: 2px solid #cda34f;
        }

        /* Footer (Repeating) */
        .footer {
            position: fixed;
            bottom: -70px;
            left: 0px;
            right: 0px;
            height: 90px;
        }

        /* Title */
        .invoice-title {
            text-align: right;
            font-size: 32px;
            font-weight: bold;
            color: #2e5aac;
        }

        /* Meta */
        .invoice-meta {
            margin-top: 5px;
        }

        .invoice-meta td {
            padding: 2px 0;
            text-align: right;
        }

        /* Separator */
        .separator {
            border-top: 1px solid #ccc;
            margin: 15px 0;
            clear: both;
        }

        /* Section Title */
        .section-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 5px;
        }

        /* Bill To */
        .bill-to {
            line-height: 1.6;
        }

        /* Main Table */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table th {
            background: #2e5aac;
            color: #fff;
            padding: 10px;
            font-size: 11px;
            text-align: left;
        }

        .table td {
            padding: 10px;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }

        .table tr.order-start td { border-top: 1px solid #ddd; }
        .table tr.order-end td { border-bottom: 1px solid #ddd; }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        /* Summary Box */
        .summary {
            width: 320px;
            float: right;
            margin-top: 20px;
            border: 1px solid #ddd;
        }

        .summary td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .summary tr:last-child td { border-bottom: none; }

        .summary .total {
            background: #d69e2e;
            color: white;
            font-weight: bold;
            font-size: 16px;
        }
        
        .summary .discount { background: #f8f9fa; }
        
        .signature { margin-top: 40px; }
        .signature-line { width: 200px; border-top: 1px solid #000; margin-bottom: 5px; }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="header">
        {% if showHeader %}
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="15%" valign="middle" align="center">
                    {% if logo %}<img src="{{ logo }}" style="max-height: 80px; max-width: 100%;" alt="UHS">{% else %}<div style="font-size: 24px; font-weight: bold; color: #c94b26;">UHS</div>{% endif %}
                </td>
                <td width="85%" valign="middle" style="padding-left: 15px;">
                    <div style="font-family: 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; margin-bottom: 5px; letter-spacing: 1px;">
                        <span style="color: #c94b26;">UNIQUE</span>
                        <span style="color: #1b887a;"> HEALTHCARE </span>
                        <span style="color: #1b2a88;">SOLUTIONS</span>
                    </div>
                    <div style="background-color: #1b2a88; color: #ffffff; display: inline-block; padding: 5px 15px; font-size: 13px; font-weight: bold;">
                        EXCELLENT IN DIAGNOSTIC SERVICES
                    </div>
                </td>
            </tr>
        </table>
        {% endif %}
    </div>

    <!-- CONTENT CONTAINER -->
    <div class="container">
        <!-- INFO SECTION (FACE TO FACE) -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="55%" valign="top">
                    <div class="section-title">Bill To:</div>
                    <table class="bill-to" cellpadding="0" cellspacing="0" border="0">
                        <tr><td><strong>Name:</strong></td><td style="padding-left: 10px;">{{ customer.name }}</td></tr>
                        <tr><td><strong>Address:</strong></td><td style="padding-left: 10px;">{{ customer.address|default('N/A') }}</td></tr>
                        <tr><td><strong>City:</strong></td><td style="padding-left: 10px;">{{ customer.city|default('N/A') }}</td></tr>
                        <tr><td><strong>Phone:</strong></td><td style="padding-left: 10px;">{{ customer.phone }}</td></tr>
                    </table>
                </td>
                <td width="45%" valign="top" align="right">
                    <div class="invoice-title" style="font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif; margin-bottom: 5px;">LEDGER</div>
                    <table class="invoice-meta" align="right">
                        <tr><td><strong>Ledger No:</strong></td><td style="padding-left: 15px;">{{ statementNumber|default('STMT-' ~ "now"|date("Ymd")) }}</td></tr>
                        <tr><td><strong>Timeline:</strong></td><td style="padding-left: 15px;">{{ periodLabel|default('All Time') }}</td></tr>
                        <tr><td><strong>Date:</strong></td><td style="padding-left: 15px;">{{ date|date('d-m-Y') }}</td></tr>
                        <tr><td><strong>Maker:</strong></td><td style="padding-left: 15px;">{{ invoiceMaker|default('N/A') }}</td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <!-- TRANSACTIONS TABLE -->
        <table class="table">
            <thead>
                <tr><th width="5%">Sr</th><th>Item Name</th><th>Description</th><th width="10%">Qty</th><th width="15%">Unit Price</th><th width="15%">Total</th></tr>
            </thead>
            <tbody>
                {% set sr = 1 %}
                {% for order in orders %}
                    {% for item in order.items %}
                    <tr class="{% if loop.first %}order-start{% endif %} {% if loop.last %}order-end{% endif %}">
                        <td class="text-center">{% if loop.first %}{{ sr }}{% endif %}</td>
                        <td><strong>{{ item.name }}</strong><br><span style="font-size:9px;color:#777;">(Order #{{ order.orderId }} - {{ order.date|date('d-m-Y') }})</span></td>
                        <td>
                            {{ item.description }}
                            {% if item.discountPercentage > 0 %}<div style="color: #c0392b; font-size: 9px; font-weight: bold;">-{{ item.discountPercentage }}% (PKR {{ item.discountAmount|number_format(2) }})</div>{% endif %}
                            {% if loop.last %}
                                {% if order.discountAmount > 0 and not item.discountPercentage %}<div style="color:green; font-size:10px;">Disc: {{ order.discountPercentage }}% (PKR {{ order.discountAmount|number_format(2) }})</div>{% endif %}
                                {% if order.pending > 0 %}<div style="color:red; font-size:10px;">Pending: PKR {{ order.pending|number_format(2) }}</div>{% endif %}
                            {% endif %}
                        </td>
                        <td class="text-center">{{ item.quantity }}</td>
                        <td class="text-right">PKR {{ item.price|number_format(2) }}</td>
                        <td class="text-right">PKR {{ item.total|number_format(2) }}</td>
                    </tr>
                    {% endfor %}
                    {% set sr = sr + 1 %}
                {% else %}
                    <tr><td colspan="6" class="text-center">No activity recorded.</td></tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- SUMMARY -->
        <table class="summary">
            <tr><td>Subtotal:</td><td class="text-right">PKR {{ subTotal|number_format(2) }}</td></tr>
            {% if totalDiscount > 0 %}<tr class="discount"><td>Total Discount:</td><td class="text-right">- PKR {{ totalDiscount|number_format(2) }}</td></tr>{% endif %}
            <tr class="total"><td>Grand Total:</td><td class="text-right">PKR {{ totalSpent|number_format(2) }}</td></tr>
        </table>
        <div style="clear: both;"></div>

        {% if customerRemainingBalance is defined and customerRemainingBalance > 0 %}
            <div style="margin-top: 10px; text-align: right; color: red; font-weight: bold;">Outstanding Balance: PKR {{ customerRemainingBalance|number_format(2) }}</div>
        {% endif %}

        <div class="signature">
            <div class="signature-line"></div>
            Authorized Signature
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        {% if showHeader %}
        <div style="background-color: #1b2a88; color: #ffffff; text-align: center; padding: 6px; font-size: 11px; font-weight: bold; margin-bottom: 8px;">
            WHOLESALE DISTRIBUTOR OF LAB DISPOSABLE ITEMS & DIAGNOSTIC REAGENTS
        </div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 8px;">
            <tr>
                <td width="40%" style="font-size: 10px; font-weight: bold;">HALI ROAD TEHSIL CHOWK, SAHIWAL PUNJAB PAKISTAN</td>
                <td width="25%" align="center" style="font-size: 12px; font-weight: bold;">0312 7171837</td>
                <td width="35%" align="right" style="font-size: 11px; font-weight: bold;">uniquehealthcaresolution.swl@gmail.com</td>
            </tr>
        </table>
        <div style="background-color: #cda34f; color: #000; text-align: center; padding: 4px; font-size: 10px; font-weight: bold;">
            Laboratory, Radiology & Hospital Equipment, Biomedical Services & General Order Supplier
        </div>
        {% endif %}
    </div>

</body>
</html>